Description:
Create a text file with student last name, district code (I or O) and number of credits taken.
Compute tuition owed (credits taken x cost per credit). Cost per credit for in district students
(district code I) is 250.00. Out of district students pay 500.00 per credit. For each line display
student last name, credits taken and tuition owed. After the loop display sum of all tuition owed
and the number of students.
"""

total_tuition = 0
number_students = 0 

file = open("textfile (2).txt")

while True:
    last_name = file.readline().strip()
    district_code = file.readline().strip()
   
    # stop when file ends
    if district_code == "":   
        break

    credits_taken = float(file.readline().strip())
    
    #Compute cost of credits
    if district_code == "I":
        cost_per_credit = 250
    else:
        cost_per_credit = 500 
    
    tuition_owed = credits_taken * cost_per_credit
        
    print("Name:",last_name)
    print("Credits Taken:",credits_taken)
    print("Tuition Owed:",tuition_owed)
    print("---------------------------")
    
    total_tuition = total_tuition + tuition_owed
    number_students = number_students + 1 
    
file.close()
print("Sum of All Tuition Owed:",total_tuition)
print("Number of Students:",number_students)
